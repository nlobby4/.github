# --------------------------------------------------
# Allowlist git ignore file.
#
# This file uses a deny-by-default approach so all files
# are ignored unless explicitly allowed via exceptions.
#
# This avoids any unwanted auto-generated files from being
# accidentally committed to the repository.
#
# By extension this file is used to exclude files from
# tooling and other processes that rely on git to determine
# which files are part of the project.
#
# Add files and paths to be tracked by git by adding exceptions,
# keep in mind to allow starting from the repository root to avoid
# allowing files provided by dependencies.
#
# Add specific file:                        !/path/to/file
# Add all files in a directory:             !/path/to/directory/
# Add all files in a directory recursively: !/path/to/directory/**
#
# A pattern that does not contain a slash matches by basename
# in any directory.
# --------------------------------------------------

# Deny by default
*

# Allow directory traversal
!*/

# Allow specific root-level files and directories
!/.editorconfig
!/.git-blame-ignore-revs
!/.gitattributes
!/.gitignore
!/.mailmap
!/.github/**
!/.vscode/**
!/*.md
!/AUTHORS
!/LICENSE
!/profile/**
